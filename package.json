{
  "name": "dleft",
  "version": "0.1.0",
  "description": "ASCII disk usage (physical disks, partitions, filesystems) for macOS and Linux.",
  "type": "module",
  "bin": {
    "dleft": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pathcosmos/cli-ascii-usage.git"
  },
  "keywords": [
    "disk",
    "usage",
    "df",
    "diskutil",
    "lsblk",
    "cli",
    "ascii",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "picocolors": "^1.0.0",
    "plist": "^3.1.0",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/plist": "^3.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
